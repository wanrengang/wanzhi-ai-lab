# MiniMax LLM 配置
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_BASE_URL=https://api.minimax.io/v1

# 数据库连接 (可选)
DATABASE_URL=sqlite+aiosqlite:///./data/analysis.db

# LangGraph 对话检查点（多轮 / 重启续聊；与 analysis.db 不同文件）
# CHECKPOINT_SQLITE_PATH=./data/checkpoints.sqlite

# 文件上传目录
UPLOAD_DIR=./data/uploads

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 日志：控制台 + 默认落盘 ./data/logs/app.log（轮转）；DEBUG 时更详细；LOG_FILE= 或 none 则仅控制台
LOG_LEVEL=INFO
LOG_FILE=./data/logs/app.log

# LangSmith（可选）：在 https://smith.langchain.com 查看智能体 / 图 / LLM / 工具 的执行轨迹
# 在 LangSmith 创建 API Key 后取消注释并填写；langsmith 通常已由 langchain 依赖带入，无需单独 pip
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_...
# LANGCHAIN_PROJECT=deepagent-pro
# 自建 LangSmith 部署时可设端点（一般留空）
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
